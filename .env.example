# Database (Neon PostgreSQL)
# DATABASE_URL = pooled connection (host contains "-pooler") — used by the app at runtime.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require"
# DIRECT_URL = direct connection (same host without "-pooler") — used by Prisma CLI / migrations.
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/neondb?sslmode=require"

# JWT
JWT_SECRET="your-super-secret-jwt-key-min-32-chars"
JWT_EXPIRES_IN="7d"

# Upstash Redis
UPSTASH_REDIS_REST_URL="https://[YOUR-ENDPOINT].upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# Cloudflare R2
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET_NAME="anjeurn-assets"
R2_PUBLIC_URL="https://pub-[hash].r2.dev"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# SendGrid (email notifications)
SENDGRID_API_KEY="SG.your-api-key"
SENDGRID_FROM_EMAIL="noreply@yourdomain.com"

# Upstash QStash (async job queue for notifications)
QSTASH_TOKEN="your-qstash-token"

# Internal secret for /api/notify/email webhook
NOTIFY_SECRET="your-random-secret"
