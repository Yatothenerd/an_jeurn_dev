generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  admin
  client
}

enum GuestControlType {
  none
  limited
  full
}

enum UserPackageStatus {
  active
  expired
  revoked
}

enum ContactType {
  email
  phone
  whatsapp
}

model User {
  id              String        @id @default(cuid())
  name            String
  email           String        @unique
  passwordHash    String        @map("password_hash")
  role            Role          @default(client)
  createdAt       DateTime      @default(now()) @map("created_at")

  events          Event[]
  userPackages    UserPackage[] @relation("UserToPackage")
  grantedPackages UserPackage[] @relation("GrantedByAdmin")

  @@map("users")
}

model Package {
  id               String           @id @default(cuid())
  name             String
  slug             String           @unique
  priceUsd         Decimal          @map("price_usd") @db.Decimal(10, 2)
  maxSections      Int              @map("max_sections")
  maxPhotos        Int              @map("max_photos")
  maxGuests        Int              @map("max_guests")
  hasMusic         Boolean          @default(false) @map("has_music")
  hasVideo         Boolean          @default(false) @map("has_video")
  hasKhqr          Boolean          @default(false) @map("has_khqr")
  hasWishing       Boolean          @default(false) @map("has_wishing")
  hasHosting       Boolean          @default(false) @map("has_hosting")
  hasCustomThumb   Boolean          @default(false) @map("has_custom_thumb")
  hasLocation      Boolean          @default(false) @map("has_location")
  hasOpeningCover  Boolean          @default(false) @map("has_opening_cover")
  hasWatermark     Boolean          @default(true)  @map("has_watermark")
  hasGuestControl  Boolean          @default(false) @map("has_guest_control")
  guestControlType GuestControlType @default(none)  @map("guest_control_type")
  guestEditLimit   Int?             @map("guest_edit_limit")
  hasLogo          Boolean          @default(false) @map("has_logo")
  galleryType      String?          @map("gallery_type")
  createdAt        DateTime         @default(now()) @map("created_at")

  userPackages     UserPackage[]
  templates        PackageTemplate[]

  @@map("packages")
}

model UserPackage {
  id          String            @id @default(cuid())
  userId      String            @map("user_id")
  packageId   String            @map("package_id")
  createdBy   String            @map("created_by")
  grantedAt   DateTime          @default(now()) @map("granted_at")
  expiresAt   DateTime?         @map("expires_at")
  status      UserPackageStatus @default(active)
  notes       String?

  user        User              @relation("UserToPackage",   fields: [userId],    references: [id], onDelete: Cascade)
  package     Package           @relation(                   fields: [packageId], references: [id])
  grantedBy   User              @relation("GrantedByAdmin",  fields: [createdBy], references: [id])

  @@map("user_packages")
}

model Event {
  id          String      @id @default(cuid())
  userId      String      @map("user_id")
  title       String
  eventType   String      @map("event_type")
  eventDate   DateTime    @map("event_date")
  venueName   String?     @map("venue_name")
  venueMapUrl String?     @map("venue_map_url")
  slug        String      @unique
  status      String      @default("draft")
  createdAt   DateTime    @default(now()) @map("created_at")

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  invitation  Invitation?
  guests      Guest[]

  @@map("events")
}

// All invitation design — sections, assets, color scheme — is set directly by admin.
// There is no separate Theme model; admin configures each event's look here.
model Invitation {
  id                 String   @id @default(cuid())
  eventId            String   @unique @map("event_id")

  // Design config (set by admin via EventWizard)
  contentType        String?  @default("photo") @map("content_type")
  defaultSections    Json?    @map("default_sections")
  overlayConfig      Json?    @map("overlay_config")
  backgroundUrl      String?  @map("background_url")
  backgroundVideoUrl String?  @map("background_video_url")
  coverUrl           String?  @map("cover_url")
  thumbnailUrl       String?  @map("thumbnail_url")
  previewUrl         String?  @map("preview_url")
  musicUrl           String?  @map("music_url")
  isAnimated         Boolean  @default(false) @map("is_animated")

  // Delivery
  shareLink     String?  @map("share_link")
  showWatermark Boolean  @default(true)  @map("show_watermark")
  isPublished   Boolean  @default(false) @map("is_published")
  createdAt     DateTime @default(now()) @map("created_at")

  event    Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  sections Section[]
  photos   Photo[]
  wishes   Wish[]

  @@map("invitations")
}

model Section {
  id           String     @id @default(cuid())
  invitationId String     @map("invitation_id")
  type         String
  sortOrder    Int        @default(0) @map("sort_order")
  content      Json
  isVisible    Boolean    @default(true) @map("is_visible")
  createdAt    DateTime   @default(now()) @map("created_at")

  invitation   Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)

  @@map("sections")
}

model Photo {
  id           String     @id @default(cuid())
  invitationId String     @map("invitation_id")
  url          String
  sortOrder    Int        @default(0) @map("sort_order")

  invitation   Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)

  @@map("photos")
}

model Wish {
  id           String     @id @default(cuid())
  invitationId String     @map("invitation_id")
  guestName    String     @map("guest_name")
  message      String
  createdAt    DateTime   @default(now()) @map("created_at")

  invitation   Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)

  @@map("wishes")
}

model Guest {
  id          String       @id @default(cuid())
  eventId     String       @map("event_id")
  token       String?      @unique
  name        String
  contact     String?
  contactType ContactType? @map("contact_type")
  rsvpStatus  String?      @map("rsvp_status")
  mealPref    String?      @map("meal_pref")
  rsvpAt      DateTime?    @map("rsvp_at")

  event       Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("guests")
}

// A reusable design preset ("template theme"). It captures the same design bundle
// an Invitation holds (overlayConfig, section layout, background/cover assets) but
// no event-specific content. Admins build these in the Theme Builder and tag them
// to packages; a client/admin can then apply one to a real event's invitation.
model Template {
  id                 String   @id @default(cuid())
  name               String
  contentType        String?  @default("photo") @map("content_type")
  defaultSections    Json?    @map("default_sections")
  overlayConfig      Json?    @map("overlay_config")
  backgroundUrl      String?  @map("background_url")
  backgroundVideoUrl String?  @map("background_video_url")
  coverUrl           String?  @map("cover_url")
  thumbnailUrl       String?  @map("thumbnail_url")
  previewUrl         String?  @map("preview_url")
  musicUrl           String?  @map("music_url")
  isAnimated         Boolean  @default(false) @map("is_animated")
  isActive           Boolean  @default(true)  @map("is_active")
  sortOrder          Int      @default(0)     @map("sort_order")
  createdAt          DateTime @default(now()) @map("created_at")

  packages           PackageTemplate[]

  @@map("templates")
}

// Join table tagging which packages may use a template (Package A, Package B, …).
model PackageTemplate {
  id         String   @id @default(cuid())
  packageId  String   @map("package_id")
  templateId String   @map("template_id")
  createdAt  DateTime @default(now()) @map("created_at")

  package    Package  @relation(fields: [packageId],  references: [id], onDelete: Cascade)
  template   Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([packageId, templateId])
  @@map("package_templates")
}
